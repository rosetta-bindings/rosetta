endif()
find_package(Lua 5.4 EXACT QUIET)
if(NOT LUA_INCLUDE_DIR)
    find_path(LUA_INCLUDE_DIR lua.h
        PATH_SUFFIXES lua5.4 lua-5.4 lua luajit-2.1
        PATHS /opt/homebrew/opt/lua@5.4/include /usr/local/opt/lua@5.4/include
              /opt/homebrew/include /usr/local/include /usr/include
        NO_DEFAULT_PATH)
    find_library(LUA_LIBRARIES NAMES lua5.4 lua-5.4 lua luajit-5.1
        PATHS /opt/homebrew/opt/lua@5.4/lib /usr/local/opt/lua@5.4/lib
              /opt/homebrew/lib /usr/local/lib /usr/lib
        NO_DEFAULT_PATH)
endif()
if(NOT LUA_INCLUDE_DIR)
    find_package(Lua QUIET) # any other 5.1–5.3 / LuaJIT
endif()
if(NOT LUA_INCLUDE_DIR)
    message(FATAL_ERROR
        "Lua not found — pass -DLUA_INCLUDE_DIR=<dir of lua.h> and -DLUA_LIBRARIES=<liblua>.")
endif()
message(STATUS "Lua headers: ${LUA_INCLUDE_DIR}")
file(STRINGS "${LUA_INCLUDE_DIR}/lua.h" _rosetta_lua_ver REGEX "define[ \t]+LUA_VERSION_NUM")
